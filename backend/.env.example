# --- Database (REQUIRED) ---------------------------------------------------
# Must be set. Examples:
#   SQLite (local dev):  DATABASE_URL=sqlite:///./siz_control.db
#   PostgreSQL (prod):   DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./siz_control.db

# --- Security --------------------------------------------------------------
# Generate a long random string, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_use_a_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=720

# --- First administrator (created on seed) ---------------------------------
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin123
ADMIN_FULL_NAME=Администратор системы

# --- CORS (REQUIRED) -------------------------------------------------------
# Comma-separated list of allowed frontend origins.
# Examples:
#   CORS_ORIGINS=*
#   CORS_ORIGINS=https://my-app.amvera.io,http://localhost:5173
CORS_ORIGINS=*

# --- File uploads ----------------------------------------------------------
UPLOAD_DIR=./uploads

# --- Platform SSO (Keycloak) — OPTIONAL, OFF by default --------------------
# When OFF (default) the app behaves exactly as before (login/password only).
# Turn ON to enable Keycloak token verification (steps 1-2 wired only).
PLATFORM_SSO=false
KEYCLOAK_ISSUER=https://keycloak-ashinoff.amvera.io/realms/platform
KEYCLOAK_JWKS_URL=https://keycloak-ashinoff.amvera.io/realms/platform/protocol/openid-connect/certs
KEYCLOAK_AZP=web-desktop
