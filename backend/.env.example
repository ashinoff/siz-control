# --- Database --------------------------------------------------------------
# Local development (zero config) uses SQLite by default. For production set a
# PostgreSQL URL, e.g. from Supabase (Free) or Render Postgres:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./siz_control.db

# --- Security --------------------------------------------------------------
# Generate a long random string, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_use_a_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=720

# --- First administrator (created on seed) ---------------------------------
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin123
ADMIN_FULL_NAME=Администратор системы

# --- CORS ------------------------------------------------------------------
# Comma-separated list of allowed frontend origins, or * for any.
# In production set this to your deployed frontend URL.
CORS_ORIGINS=*

# --- File uploads ----------------------------------------------------------
UPLOAD_DIR=./uploads
